    "overrides": {
        "_comment_material": "Common to all benchmarks (defined in common defaults)",
        "material": {
            "density": 2670,
            "lambda_o": 3.204e10,
            "shear_modulus_o": 3.204e10
        },

        "_comment_slip_weakening": "All benchmarks; values vary per benchmark",
        "slip_weakening": {
            "q": "0.2 (tpv205_2d_tria) | 0.1 (tpv205_2d_quad, tpv205_3d) | 0.4 (tpv26_3d)",
            "Dc": "0.4 (tpv205_*) | 0.3 (tpv26_3d)",
            "T2_o": "120e6 (tpv205_* only)",
            "T3_o": "0.0 (tpv205_3d only)",
            "mu_s": "0.677 (tpv205_2d only) | 0.18 (tpv26_3d only)",
            "mu_d": "0.525 (tpv205_*) | 0.12 (tpv26_3d)",
            "len": "200 (tpv205_2d_*) | 100 (tpv205_3d, tpv26_3d)"
        },

        "_comment_initial_shear_stress": "tpv205_2d only; piecewise shear stress along fault",
        "initial_shear_stress": {
            "T1_o": "70.0e6 (tpv205_2d only) — background shear stress",
            "T1_o_elevated": "78.0e6 (tpv205_2d only) — elevated stress patch",
