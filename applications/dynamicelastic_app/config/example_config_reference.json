{
    "_comment": "Reference config showing ALL possible fields across all benchmarks. Values shown are defaults from defaults.json. Only include fields in your config that you want to override.",

    "benchmark": "tpv205_2d | tpv205_3d | tpv26_3d",
    "mesh_variant": "tria | quad  (only for tpv205_2d; default: tria)",
    "output_dir": "(optional) override output directory",
