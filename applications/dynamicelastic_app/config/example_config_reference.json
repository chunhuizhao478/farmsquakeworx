            "mesh_file": "(tpv205_2d_tria, tpv205_3d, tpv26_3d)",
            "nx": "(tpv205_2d_quad only)",
            "ny": "(tpv205_2d_quad only)",
            "xmin": "(tpv205_2d_quad only)",
            "xmax": "(tpv205_2d_quad only)",
            "ymin": "(tpv205_2d_quad only)",
            "ymax": "(tpv205_2d_quad only)",
            "elem_size": "(tpv26_3d only)",
            "xmin_fault": "(tpv26_3d only)",
            "xmax_fault": "(tpv26_3d only)",
